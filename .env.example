NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-your-anon-key"
# Chave "service_role" do Supabase (Project Settings → API). NUNCA exponha com prefixo
# NEXT_PUBLIC_ nem importe fora de código server-only — usada apenas no painel SaaS
# (app/superadmin) para convidar novos clientes por e-mail.
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"

# Cloudflare R2 (armazenamento de imagens dos produtos). NUNCA exponha ACCESS_KEY_ID
# ou SECRET_ACCESS_KEY com prefixo NEXT_PUBLIC_ — usadas apenas em Server Actions/rotas
# server-only para gerar o upload assinado. A URL pública é o único valor client-safe.
CLOUDFLARE_ACCOUNT_ID="replace-with-your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="replace-with-your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="replace-with-your-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET_NAME="replace-with-your-bucket-name"
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
NEXT_PUBLIC_CLOUDFLARE_R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"
